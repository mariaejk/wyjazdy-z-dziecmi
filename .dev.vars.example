# Cloudflare Workers — local development secrets
# Copy to .dev.vars and fill in values

# Airtable (form data storage)
AIRTABLE_API_KEY=pat...
AIRTABLE_BASE_ID=app...

# Resend (transactional emails)
RESEND_API_KEY=re_...
FROM_EMAIL=kontakt@wyjazdyzdziecmi.pl
OWNER_EMAIL=maria@example.com

# Cloudflare Turnstile (spam protection)
TURNSTILE_SECRET_KEY=0x...

# Keystatic CMS (GitHub mode)
NEXT_PUBLIC_KEYSTATIC_GITHUB_OWNER=mariaejk
NEXT_PUBLIC_KEYSTATIC_GITHUB_REPO=wyjazdy-z-dziecmi
KEYSTATIC_GITHUB_CLIENT_ID=...
KEYSTATIC_GITHUB_CLIENT_SECRET=...
KEYSTATIC_SECRET=...
