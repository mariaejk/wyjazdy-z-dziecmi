# Google Analytics
NEXT_PUBLIC_GA_ID=

# Microsoft Clarity
NEXT_PUBLIC_CLARITY_ID=

# Webhook URLs (n8n integration - future)
BOOKING_WEBHOOK_URL=
CONTACT_WEBHOOK_URL=
NEWSLETTER_WEBHOOK_URL=

# Keystatic CMS — Admin panel authentication (HTTP Basic Auth)
# Leave empty for open access in development
KEYSTATIC_ADMIN_USER=
KEYSTATIC_ADMIN_PASSWORD=

# Keystatic CMS — GitHub mode (for collaborative editing on Vercel)
# When both are set, Keystatic uses GitHub storage instead of local files.
# Create a GitHub App or use a personal access token for authentication.
NEXT_PUBLIC_KEYSTATIC_GITHUB_OWNER=
NEXT_PUBLIC_KEYSTATIC_GITHUB_REPO=
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
KEYSTATIC_SECRET=
