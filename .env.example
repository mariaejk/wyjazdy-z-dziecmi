# Google Analytics
NEXT_PUBLIC_GA_ID=

# Microsoft Clarity
NEXT_PUBLIC_CLARITY_ID=

# ============================================
# AIRTABLE (zapis leadów)
# ============================================
# https://airtable.com/create/tokens → Personal Access Token z `data.records:write`
# Instrukcja konfiguracji: docs/setup-external-services.md
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=

# ============================================
# RESEND (emaile)
# ============================================
# https://resend.com → API Keys → Create
RESEND_API_KEY=
# Email "Od:" — musi być z zweryfikowanej domeny w Resend
FROM_EMAIL="Wyjazdy z Dziećmi <kontakt@wyjazdyzdziecmi.pl>"
# Twój email na który przychodzą powiadomienia
OWNER_EMAIL=wyjazdyzdziecmi@gmail.com

# ============================================
# CLOUDFLARE TURNSTILE (antyspam)
# ============================================
# https://dash.cloudflare.com → Turnstile → Add Site
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Keystatic CMS — Admin panel authentication (HTTP Basic Auth)
# Leave empty for open access in development
KEYSTATIC_ADMIN_USER=
KEYSTATIC_ADMIN_PASSWORD=

# Keystatic CMS — GitHub mode (for collaborative editing on Vercel)
# When both are set, Keystatic uses GitHub storage instead of local files.
# Create a GitHub App or use a personal access token for authentication.
NEXT_PUBLIC_KEYSTATIC_GITHUB_OWNER=
NEXT_PUBLIC_KEYSTATIC_GITHUB_REPO=
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
KEYSTATIC_SECRET=
